# Microsoft Azure AD OAuth2 Credentials
WORKDAY_CLIENT_ID=your_workday_client_id_here
WORKDAY_CLIENT_SECRET=your_workday_client_secret_here

# Workday API Endpoints
WORKDAY_TOKEN_URL=https://login.microsoftonline.com/18a59a81-eea8-4c30-948a-d8824cdc2580/oauth2/v2.0/token
WORKDAY_API_URL=https://gateway.apim.lilly.com/workforce_fastapi/GWF_Workers
WORKDAY_SCOPE=api://emerald_workforce.lilly.com/.default

PROOFPOINT_API_KEY=your_proofpoint_api_key_here

# Proofpoint API Endpoint
PROOFPOINT_BASE_URL=https://results.us.securityeducation.com/api/reporting/v0.3.0/phishing_extended

# Start date for filtering terminated employees in Workday
CAMPAIGN_START_DATE=2026-01-21

# Date range for Proofpoint phishing campaign data
PROOFPOINT_START_DATE=2026-01-21
PROOFPOINT_END_DATE=2026-01-23

# Number of records to fetch per page (max: 500)
PROOFPOINT_PAGE_SIZE=500

# SSL certificate verification (True/False)
PROOFPOINT_VERIFY_SSL=False

# Delay between API requests in seconds (prevents rate limiting)
PROOFPOINT_RATE_LIMIT_DELAY=1.0

# Delay before retrying after 429 error (seconds)
PROOFPOINT_RETRY_DELAY=5.0

# Maximum number of retries for failed requests
PROOFPOINT_MAX_RETRIES=3

# Output file paths (use raw strings for Windows paths)
OUTPUT_EXCEL_PATH=C:\WorkdaySADFeed\Merged_Campaign_Details.xlsx
OUTPUT_CSV_PATH=C:\WorkdaySADFeed\Merged_Campaign_Details.csv

LOG_LEVEL=INFO
LOG_FILE_PATH=C:\WorkdaySADFeed\logs\campaign_merge.log
LOG_TO_FILE=true
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
LOG_USE_UTC=false