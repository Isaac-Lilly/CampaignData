# ============================================================
# Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# ── Workday ──────────────────────────────────────────────────
WORKDAY_CLIENT_ID=your-workday-client-id
WORKDAY_CLIENT_SECRET=your-workday-client-secret
WORKDAY_TOKEN_URL=https://your-tenant.workday.com/ccx/oauth2/your-tenant/token
WORKDAY_API_URL=https://your-tenant.workday.com/ccx/api/your-endpoint
WORKDAY_SCOPE=your-workday-scope

# Campaign start date — used to filter terminated workers and as the
# Tenure reference date (format: YYYY-MM-DD).
CAMPAIGN_START_DATE=2026-03-02

# ── Proofpoint ───────────────────────────────────────────────
# Full URL to the phishing_extended reporting endpoint.
PROOFPOINT_BASE_URL=https://results.us.securityeducation.com/api/reporting/v0.3.0/phishing_extended
PROOFPOINT_API_KEY=your-proofpoint-api-key

# Date window for fetching Proofpoint campaign records (YYYY-MM-DD).
PROOFPOINT_START_DATE=2026-03-02
PROOFPOINT_END_DATE=2026-03-09

# Pagination / reliability tuning (defaults shown).
PROOFPOINT_PAGE_SIZE=500
PROOFPOINT_VERIFY_SSL=False
PROOFPOINT_RATE_LIMIT_DELAY=1.0
PROOFPOINT_RETRY_DELAY=5.0
PROOFPOINT_MAX_RETRIES=3

# ── Splunk ───────────────────────────────────────────────────
SPLUNK_HOST=https://lilly-infosec.splunkcloud.com:8089
SPLUNK_API_KEY=your-splunk-token

# Campaign window used for Proofpoint Splunk index scoping and
# Phase 3 single-email retry queries (ISO datetime, no timezone).
SPLUNK_CAMPAIGN_EARLIEST=2026-03-02T00:00:00
SPLUNK_CAMPAIGN_LATEST=2026-03-09T23:59:59

# ±window (minutes) around each user's anchor event for AzureAD queries.
# Default 1440 = ±24 hours.
SPLUNK_TIME_WINDOW_MINUTES=1440

# Performance / reliability tuning (defaults shown).
SPLUNK_BATCH_SIZE=500
SPLUNK_SUBMIT_DELAY=3
SPLUNK_MAX_RETRIES=5
SPLUNK_RETRY_DELAY=10
SPLUNK_INITIAL_POLL=5
SPLUNK_RETRY_JOB_DELAY=3

# Hard timeout per Splunk job in seconds (default 600 = 10 minutes).
SPLUNK_JOB_TIMEOUT=600

# ── Output Paths ─────────────────────────────────────────────
# Windows-style paths shown; update for your environment.
OUTPUT_EXCEL_PATH=C:\WorkdaySADFeed\Merged_Campaign_Details_March26Final.xlsx
OUTPUT_CSV_PATH=C:\WorkdaySADFeed\Merged_Campaign_Details_March26Final.csv

# ── Logging ──────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Set to true to also write logs to a rotating file.
LOG_TO_FILE=false

# Leave blank to auto-place logs next to the Excel output file.
LOG_FILE_PATH=

# Max size per log file in bytes (default 5 MB).
LOG_MAX_BYTES=5242880

# Number of rotated log files to keep.
LOG_BACKUP_COUNT=5

# Set to true to use UTC timestamps in log lines; false = local time.
LOG_USE_UTC=false
